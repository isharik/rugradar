# ---------------------------------------------------------------------------
# RugRadar configuration. Copy to `.env` and fill in as needed.
# NOTHING here is required to run the core risk engine — all risk data sources
# used in v1 are FREE and keyless. The payment-related vars are used ONLY when
# the OKX Payment SDK is wired in (Phase 5) and are safe to leave blank until then.
# ---------------------------------------------------------------------------

# ---- Payment layer (swappable: testnet for building, mainnet for going live) ----
# Controls which X Layer network the OKX Payment SDK settles on.
# Allowed values: "testnet" | "mainnet". Default: testnet (keeps you at ~$0).
PAYMENT_MODE=testnet

# The per-call price other agents pay to call assess_token_risk.
# OKX ASP fees are denominated in USDT (digits only; no unit/symbol).
# Set small — the A2MCP model is sub-cent, high-volume. Example: 0.01 (= 0.01 USDT)
PRICE_PER_CALL=0.01

# OKX Agentic Wallet / Payment SDK credentials (Phase 5 — leave blank for now).
# You obtain these from the OKX Developer Portal + your Agentic Wallet.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# ---- Risk-data layer (mainnet reads; all FREE / keyless) ----
# Default chain to assume when a caller omits the chain. 1 = Ethereum mainnet.
DEFAULT_CHAIN_ID=1

# Optional: override or add public RPC URLs (comma-separated) per chain.
# If unset, built-in free public RPCs are used. Example:
# RPC_URLS_1=https://cloudflare-eth.com,https://rpc.ankr.com/eth
RPC_URLS_1=
RPC_URLS_56=
RPC_URLS_8453=

# Optional: GoPlus is used as an OPTIONAL enrichment source. No key needed for
# basic use. If it is unreachable, RugRadar degrades gracefully (lower
# confidence + notes the missing source) instead of failing the call.
GOPLUS_ENABLED=true

# Per-source network timeout in milliseconds.
SOURCE_TIMEOUT_MS=6000

# ---- HTTP transport (optional live endpoint) ----
HTTP_PORT=8787
